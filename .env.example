# Local development uses .env.development.local (gitignored) which should
# point at the QA Supabase project so accidental writes never touch real data.
#
# For production-build verification (`npm run preview` against PRD), use
# .env.production.local (also gitignored).
#
# In Vercel, env vars are configured in the dashboard per environment:
#   Production environment  -> PRD Supabase URL + anon key
#   Preview environment     -> QA Supabase URL + anon key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
